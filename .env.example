# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# Gmail SMTP — fill in locally (never commit real passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
